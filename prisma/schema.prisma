model User {
  id                        String    @id @default(cuid())
  name                      String
  email                     String    @unique
  passwordHash              String?
  authProviderId            String?
  role                      UserRole
  isActive                  Boolean   @default(true)
  emailVerifiedAt           DateTime?
  lastLoginAt               DateTime?
  lastPasswordChangeAt      DateTime?
  failedLoginAttempts       Int       @default(0)
  lockedUntil               DateTime?
  deactivatedAt             DateTime?
  deactivatedById           String?
  confidentialityAcceptedAt DateTime?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  clientsResponsible            Client[]                   @relation("ClientResponsible")
  clientsCreated                Client[]                   @relation("ClientCreatedBy")
  designersResponsible          Designer[]                 @relation("DesignerResponsible")
  designersCreated              Designer[]                 @relation("DesignerCreatedBy")
  objectsResponsible            ProjectObject[]            @relation("ObjectResponsible")
  objectsCreated                ProjectObject[]            @relation("ObjectCreatedBy")
  objectParticipantsResponsible ProjectObjectParticipant[] @relation("ObjectParticipantResponsible")
  objectParticipantsCreated     ProjectObjectParticipant[] @relation("ObjectParticipantCreatedBy")
  dealsResponsible              Deal[]                     @relation("DealResponsible")
  dealsCreated                  Deal[]                     @relation("DealCreatedBy")
  proposalsResponsible          CommercialProposal[]       @relation("ProposalResponsible")
  proposalsCreated              CommercialProposal[]       @relation("ProposalCreatedBy")
  proposalsUploaded             CommercialProposal[]       @relation("ProposalUploadedBy")
  tasksResponsible              TaskActivity[]             @relation("TaskResponsible")
  tasksCreated                  TaskActivity[]             @relation("TaskCreatedBy")
  auditLogs                     AuditLog[]                 @relation("AuditLogUser")
  crmViolationsResponsible      CrmViolation[]             @relation("CrmViolationResponsible")
  crmViolationsResolved         CrmViolation[]             @relation("CrmViolationResolvedBy")
  bonusAgreementsCreated        DesignerBonusAgreement[]   @relation("DesignerBonusAgreementCreatedBy")
  bonusAgreementsApproved       DesignerBonusAgreement[]   @relation("DesignerBonusAgreementApprovedBy")
  paymentsCreated               Payment[]                  @relation("PaymentCreatedBy")
  paymentsConfirmed             Payment[]                  @relation("PaymentConfirmedBy")
  bonusAccrualsCreated          DesignerBonusAccrual[]     @relation("DesignerBonusAccrualCreatedBy")
  bonusAccrualsApproved         DesignerBonusAccrual[]     @relation("DesignerBonusAccrualApprovedBy")
  bonusPayoutsCreated           DesignerBonusPayout[]      @relation("DesignerBonusPayoutCreatedBy")
  bonusPayoutsApproved          DesignerBonusPayout[]      @relation("DesignerBonusPayoutApprovedBy")
  bonusPayoutsPaid              DesignerBonusPayout[]      @relation("DesignerBonusPayoutPaidBy")
  bonusAdjustmentsCreated       DesignerBonusAdjustment[]  @relation("DesignerBonusAdjustmentCreatedBy")
  bonusAdjustmentsApproved      DesignerBonusAdjustment[]  @relation("DesignerBonusAdjustmentApprovedBy")
  securityLogs                  SecurityLog[]              @relation("SecurityLogUser")
  deactivatedBy                 User?                      @relation("UserDeactivatedBy", fields: [deactivatedById], references: [id])
  deactivatedUsers              User[]                     @relation("UserDeactivatedBy")
  emailVerificationTokens       EmailVerificationToken[]   @relation("EmailVerificationTokenUser")
  passwordResetTokens           PasswordResetToken[]       @relation("PasswordResetTokenUser")
  invitationsSent               UserInvitation[]           @relation("UserInvitationInvitedBy")

  @@index([role])
  @@index([isActive])
  @@index([emailVerifiedAt])
  @@index([lockedUntil])
  @@index([deactivatedById])
}

model Client {
  id               String       @id @default(cuid())
  name             String
  clientType       ClientType   @default(INDIVIDUAL)
  phone            String?
  email            String?
  messenger        String?
  city             String?
  source           ClientSource @default(SHOWROOM)
  linkedDesignerId String?
  responsibleId    String
  status           ClientStatus @default(NEW)
  comment          String?
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  archivedAt       DateTime?
  lastContactAt    DateTime?
  nextContactAt    DateTime?
  notes            String?

  responsible    User                   @relation("ClientResponsible", fields: [responsibleId], references: [id])
  createdBy      User                   @relation("ClientCreatedBy", fields: [createdById], references: [id])
  linkedDesigner Designer?              @relation("ClientLinkedDesigner", fields: [linkedDesignerId], references: [id])
  projectObjects ProjectObject[]        @relation("ObjectClient")
  deals          Deal[]                 @relation("DealClient")
  proposals      CommercialProposal[]   @relation("ProposalClient")
  tasks          TaskActivity[]         @relation("TaskClient")
  payments       Payment[]              @relation("PaymentClient")
  bonusAccruals  DesignerBonusAccrual[] @relation("DesignerBonusAccrualClient")

  @@index([responsibleId])
  @@index([createdById])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([nextContactAt])
  @@index([responsibleId, status, nextContactAt])
  @@index([responsibleId, createdAt])
}

model Designer {
  id                      String                    @id @default(cuid())
  name                    String
  studio                  String?
  role                    DesignerRole              @default(DESIGNER)
  phone                   String?
  email                   String?
  messenger               String?
  website                 String?
  city                    String?
  specialization          DesignerSpecialization[]
  projectSegment          DesignerProjectSegment?
  source                  DesignerSource            @default(DATABASE)
  responsibleId           String
  relationshipStage       DesignerRelationshipStage @default(NEW_CONTACT)
  potential               DesignerPotential         @default(B)
  loyalty                 DesignerLoyalty           @default(NEUTRAL)
  cooperationTerms        String?
  firstContactAt          DateTime?
  lastTouchAt             DateTime?
  nextStepAt              DateTime?
  nextStepText            String?
  transferredObjectsCount Int                       @default(0)
  activeObjectsCount      Int                       @default(0)
  proposalsTotalAmount    Float                     @default(0)
  paymentsTotalAmount     Float                     @default(0)
  comment                 String?
  status                  EntityStatus              @default(ACTIVE)
  createdById             String
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  archivedAt              DateTime?
  notes                   String?

  responsible      User                      @relation("DesignerResponsible", fields: [responsibleId], references: [id])
  createdBy        User                      @relation("DesignerCreatedBy", fields: [createdById], references: [id])
  linkedClients    Client[]                  @relation("ClientLinkedDesigner")
  projectObjects   ProjectObject[]           @relation("ObjectDesigner")
  deals            Deal[]                    @relation("DealDesigner")
  proposals        CommercialProposal[]      @relation("ProposalDesigner")
  tasks            TaskActivity[]            @relation("TaskDesigner")
  bonusAgreements  DesignerBonusAgreement[]  @relation("DesignerBonusAgreementDesigner")
  payments         Payment[]                 @relation("PaymentDesigner")
  bonusAccruals    DesignerBonusAccrual[]    @relation("DesignerBonusAccrualDesigner")
  bonusPayouts     DesignerBonusPayout[]     @relation("DesignerBonusPayoutDesigner")
  bonusAdjustments DesignerBonusAdjustment[] @relation("DesignerBonusAdjustmentDesigner")

  @@index([responsibleId])
  @@index([createdById])
  @@index([relationshipStage])
  @@index([potential])
  @@index([loyalty])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([lastTouchAt])
  @@index([nextStepAt])
  @@index([responsibleId, relationshipStage, lastTouchAt])
  @@index([responsibleId, nextStepAt])
}

model ProjectObject {
  id                    String                   @id @default(cuid())
  title                 String
  objectType            ObjectType
  city                  String
  region                String?
  address               String?
  clientId              String
  designerId            String?
  responsibleId         String
  stage                 ObjectStage              @default(NEW_OBJECT)
  status                ObjectStatus             @default(ACTIVE)
  implementationStartAt DateTime?
  implementationEndAt   DateTime?
  budget                Float?
  bathroomsCount        Int?
  interestCategories    ObjectInterestCategory[]
  files                 String[]                 @default([])
  comment               String?
  createdById           String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  archivedAt            DateTime?
  notes                 String?

  client        Client                     @relation("ObjectClient", fields: [clientId], references: [id])
  designer      Designer?                  @relation("ObjectDesigner", fields: [designerId], references: [id])
  responsible   User                       @relation("ObjectResponsible", fields: [responsibleId], references: [id])
  createdBy     User                       @relation("ObjectCreatedBy", fields: [createdById], references: [id])
  participants  ProjectObjectParticipant[] @relation("ObjectParticipants")
  deals         Deal[]                     @relation("DealObject")
  proposals     CommercialProposal[]       @relation("ProposalObject")
  tasks         TaskActivity[]             @relation("TaskObject")
  payments      Payment[]                  @relation("PaymentObject")
  bonusAccruals DesignerBonusAccrual[]     @relation("DesignerBonusAccrualObject")

  @@index([responsibleId])
  @@index([createdById])
  @@index([clientId])
  @@index([designerId])
  @@index([stage])
  @@index([status])
  @@index([objectType])
  @@index([createdAt])
  @@index([responsibleId, status, stage])
  @@index([responsibleId, createdAt])
}

model ProjectObjectParticipant {
  id                 String                       @id @default(cuid())
  objectId           String
  participantType    ProjectObjectParticipantType
  fullName           String
  company            String?
  role               String
  phone              String?
  email              String?
  messenger          String?
  responsibleId      String?
  comment            String?
  influenceLevel     InfluenceLevel?
  influenceType      InfluenceType?
  attitudeToSturm    AttitudeToSturm?
  decisionFactors    String?
  responsibilityZone String?
  canApproveChanges  ChangeApproval?
  whenToInvolve      String?
  createdById        String
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  archivedAt         DateTime?

  object      ProjectObject  @relation("ObjectParticipants", fields: [objectId], references: [id])
  responsible User?          @relation("ObjectParticipantResponsible", fields: [responsibleId], references: [id])
  createdBy   User           @relation("ObjectParticipantCreatedBy", fields: [createdById], references: [id])
  tasks       TaskActivity[] @relation("TaskObjectParticipant")
}

model Deal {
  id              String           @id @default(cuid())
  title           String
  clientId        String
  objectId        String
  designerId      String?
  responsibleId   String
  stage           DealStage        @default(NEW_REQUEST)
  potentialAmount Float?
  probability     DealProbability?
  nextActionAt    DateTime?
  nextActionText  String?
  source          DealSource
  lossReason      DealLossReason?
  lossComment     String?
  comment         String?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  archivedAt      DateTime?
  closedAt        DateTime?
  notes           String?

  client        Client                 @relation("DealClient", fields: [clientId], references: [id])
  projectObject ProjectObject          @relation("DealObject", fields: [objectId], references: [id])
  designer      Designer?              @relation("DealDesigner", fields: [designerId], references: [id])
  responsible   User                   @relation("DealResponsible", fields: [responsibleId], references: [id])
  createdBy     User                   @relation("DealCreatedBy", fields: [createdById], references: [id])
  proposals     CommercialProposal[]   @relation("ProposalDeal")
  tasks         TaskActivity[]         @relation("TaskDeal")
  payments      Payment[]              @relation("PaymentDeal")
  bonusAccruals DesignerBonusAccrual[] @relation("DesignerBonusAccrualDeal")

  @@index([responsibleId])
  @@index([createdById])
  @@index([clientId])
  @@index([objectId])
  @@index([designerId])
  @@index([stage])
  @@index([source])
  @@index([probability])
  @@index([nextActionAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([responsibleId, stage, archivedAt, nextActionAt])
  @@index([responsibleId, createdAt])
}

model CommercialProposal {
  id                   String                   @id @default(cuid())
  proposalNumber       String                   @unique
  dealId               String
  clientId             String
  objectId             String
  designerId           String?
  responsibleId        String
  version              Int                      @default(1)
  parentProposalId     String?
  amount               Float
  discountPercent      Float?
  discountAmount       Float?
  status               CommercialProposalStatus @default(DRAFT)
  recipientType        RecipientType?
  recipientName        String?
  recipientContact     String?
  approvalRequiredFrom String?
  sentAt               DateTime?
  nextTouchAt          DateTime?
  fileUrl              String?
  fileName             String?
  fileSize             Int?
  fileMimeType         String?
  uploadedById         String?
  uploadedAt           DateTime?
  declineReason        ProposalDeclineReason?
  declineComment       String?
  comment              String?
  createdById          String
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  archivedAt           DateTime?
  notes                String?

  deal          Deal                 @relation("ProposalDeal", fields: [dealId], references: [id])
  client        Client               @relation("ProposalClient", fields: [clientId], references: [id])
  projectObject ProjectObject        @relation("ProposalObject", fields: [objectId], references: [id])
  designer      Designer?            @relation("ProposalDesigner", fields: [designerId], references: [id])
  responsible   User                 @relation("ProposalResponsible", fields: [responsibleId], references: [id])
  createdBy     User                 @relation("ProposalCreatedBy", fields: [createdById], references: [id])
  uploadedBy    User?                @relation("ProposalUploadedBy", fields: [uploadedById], references: [id])
  parent        CommercialProposal?  @relation("ProposalVersions", fields: [parentProposalId], references: [id])
  versions      CommercialProposal[] @relation("ProposalVersions")
  tasks         TaskActivity[]       @relation("TaskProposal")

  @@index([responsibleId])
  @@index([createdById])
  @@index([dealId])
  @@index([clientId])
  @@index([objectId])
  @@index([designerId])
  @@index([status])
  @@index([nextTouchAt])
  @@index([sentAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([responsibleId, status, archivedAt, nextTouchAt])
  @@index([responsibleId, createdAt])
}

model ProposalCounter {
  year       Int      @id
  nextNumber Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model TaskActivity {
  id                   String         @id @default(cuid())
  recordType           TaskRecordType @default(TASK)
  actionType           TaskActionType @default(OTHER)
  title                String
  description          String?
  responsibleId        String
  createdById          String
  clientId             String?
  designerId           String?
  objectId             String?        @map("projectObjectId")
  dealId               String?
  proposalId           String?
  objectParticipantId  String?
  status               TaskStatus     @default(NEW)
  priority             TaskPriority   @default(NORMAL)
  dueAt                DateTime?
  completedAt          DateTime?
  result               String?
  nextStepText         String?
  nextStepAt           DateTime?
  nextStepSourceTaskId String?        @unique
  isAutoCreated        Boolean        @default(false)
  autoRule             TaskAutoRule?
  archivedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  notes                String?

  responsible       User                      @relation("TaskResponsible", fields: [responsibleId], references: [id])
  createdBy         User                      @relation("TaskCreatedBy", fields: [createdById], references: [id])
  client            Client?                   @relation("TaskClient", fields: [clientId], references: [id])
  designer          Designer?                 @relation("TaskDesigner", fields: [designerId], references: [id])
  projectObject     ProjectObject?            @relation("TaskObject", fields: [objectId], references: [id])
  deal              Deal?                     @relation("TaskDeal", fields: [dealId], references: [id])
  proposal          CommercialProposal?       @relation("TaskProposal", fields: [proposalId], references: [id])
  objectParticipant ProjectObjectParticipant? @relation("TaskObjectParticipant", fields: [objectParticipantId], references: [id])

  @@index([recordType])
  @@index([status])
  @@index([dueAt])
  @@index([responsibleId])
  @@index([clientId])
  @@index([designerId])
  @@index([objectId])
  @@index([dealId])
  @@index([proposalId])
  @@index([objectParticipantId])
  @@index([responsibleId, recordType, status, dueAt])
  @@index([responsibleId, recordType, createdAt])
  @@index([responsibleId, status, completedAt])
  @@index([responsibleId, actionType, createdAt])
  @@index([responsibleId, recordType, completedAt])
  @@index([archivedAt, status, dueAt])
  @@index([autoRule, archivedAt, status])
}

model AuditLog {
  id         String          @id @default(cuid())
  entityType AuditEntityType
  entityId   String
  action     String
  userId     String
  before     Json?
  after      Json?
  createdAt  DateTime        @default(now())

  user User @relation("AuditLogUser", fields: [userId], references: [id])
}

model CrmViolation {
  id             String               @id @default(cuid())
  entityType     AuditEntityType
  entityId       String
  violationCode  String
  severity       CrmViolationSeverity
  message        String
  responsibleId  String?
  detectedAt     DateTime             @default(now())
  resolvedAt     DateTime?
  resolvedById   String?
  status         CrmViolationStatus   @default(ACTIVE)
  canAffectBonus Boolean              @default(false)
  comment        String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  responsible User? @relation("CrmViolationResponsible", fields: [responsibleId], references: [id])
  resolvedBy  User? @relation("CrmViolationResolvedBy", fields: [resolvedById], references: [id])

  @@index([entityType, entityId])
  @@index([violationCode])
  @@index([severity])
  @@index([status])
  @@index([responsibleId])
  @@index([detectedAt])
  @@index([resolvedAt])
  @@index([entityType, entityId, status])
  @@index([status, responsibleId, detectedAt])
  @@index([status, entityType, detectedAt])
  @@index([status, canAffectBonus])
}

model DesignerBonusAgreement {
  id               String                       @id @default(cuid())
  designerId       String
  agreementType    DesignerBonusAgreementType   @default(STANDARD_PERCENT)
  bonusPercent     Float?
  calculationBase  DesignerBonusCalculationBase @default(PAYMENT_AMOUNT)
  appliesTo        DesignerBonusAppliesTo       @default(ALL_DEALS)
  specificDealIds  String[]                     @default([])
  validFrom        DateTime
  validTo          DateTime?
  status           DesignerBonusAgreementStatus @default(DRAFT)
  requiresApproval Boolean                      @default(false)
  comment          String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  archivedAt       DateTime?

  designer   Designer               @relation("DesignerBonusAgreementDesigner", fields: [designerId], references: [id])
  createdBy  User                   @relation("DesignerBonusAgreementCreatedBy", fields: [createdById], references: [id])
  approvedBy User?                  @relation("DesignerBonusAgreementApprovedBy", fields: [approvedById], references: [id])
  accruals   DesignerBonusAccrual[] @relation("DesignerBonusAccrualAgreement")

  @@index([designerId])
  @@index([status])
  @@index([validFrom])
  @@index([validTo])
  @@index([archivedAt])
  @@index([designerId, status, validFrom])
}

model Payment {
  id            String        @id @default(cuid())
  dealId        String
  clientId      String
  objectId      String
  designerId    String?
  amount        Float
  paymentDate   DateTime
  paymentType   PaymentType   @default(PARTIAL_PAYMENT)
  status        PaymentStatus @default(DRAFT)
  source        PaymentSource @default(MANUAL)
  comment       String?
  createdById   String
  confirmedById String?
  confirmedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  archivedAt    DateTime?

  deal        Deal                   @relation("PaymentDeal", fields: [dealId], references: [id])
  client      Client                 @relation("PaymentClient", fields: [clientId], references: [id])
  object      ProjectObject          @relation("PaymentObject", fields: [objectId], references: [id])
  designer    Designer?              @relation("PaymentDesigner", fields: [designerId], references: [id])
  createdBy   User                   @relation("PaymentCreatedBy", fields: [createdById], references: [id])
  confirmedBy User?                  @relation("PaymentConfirmedBy", fields: [confirmedById], references: [id])
  accruals    DesignerBonusAccrual[] @relation("DesignerBonusAccrualPayment")

  @@index([dealId])
  @@index([clientId])
  @@index([objectId])
  @@index([designerId])
  @@index([status])
  @@index([paymentType])
  @@index([paymentDate])
  @@index([createdById])
  @@index([confirmedById])
  @@index([archivedAt])
  @@index([designerId, status, paymentDate])
  @@index([dealId, status, paymentDate])
}

model DesignerBonusAccrual {
  id           String                     @id @default(cuid())
  designerId   String
  agreementId  String?
  paymentId    String?
  dealId       String
  objectId     String
  clientId     String
  baseAmount   Float
  bonusPercent Float
  bonusAmount  Float
  accrualDate  DateTime
  status       DesignerBonusAccrualStatus @default(ACCRUED)
  accrualType  DesignerBonusAccrualType   @default(AUTO_FROM_PAYMENT)
  comment      String?
  createdById  String
  approvedById String?
  approvedAt   DateTime?
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  archivedAt   DateTime?

  designer   Designer                @relation("DesignerBonusAccrualDesigner", fields: [designerId], references: [id])
  agreement  DesignerBonusAgreement? @relation("DesignerBonusAccrualAgreement", fields: [agreementId], references: [id])
  payment    Payment?                @relation("DesignerBonusAccrualPayment", fields: [paymentId], references: [id])
  deal       Deal                    @relation("DesignerBonusAccrualDeal", fields: [dealId], references: [id])
  object     ProjectObject           @relation("DesignerBonusAccrualObject", fields: [objectId], references: [id])
  client     Client                  @relation("DesignerBonusAccrualClient", fields: [clientId], references: [id])
  createdBy  User                    @relation("DesignerBonusAccrualCreatedBy", fields: [createdById], references: [id])
  approvedBy User?                   @relation("DesignerBonusAccrualApprovedBy", fields: [approvedById], references: [id])

  @@unique([designerId, paymentId, accrualType])
  @@index([designerId])
  @@index([agreementId])
  @@index([paymentId])
  @@index([dealId])
  @@index([objectId])
  @@index([clientId])
  @@index([status])
  @@index([accrualType])
  @@index([accrualDate])
  @@index([createdById])
  @@index([approvedById])
  @@index([archivedAt])
  @@index([designerId, status, accrualDate])
}

model DesignerBonusPayout {
  id               String                    @id @default(cuid())
  designerId       String
  amount           Float
  payoutDate       DateTime
  payoutMethod     DesignerBonusPayoutMethod
  status           DesignerBonusPayoutStatus @default(DRAFT)
  linkedAccrualIds String[]                  @default([])
  comment          String?
  documentFileUrl  String?
  createdById      String
  approvedById     String?
  approvedAt       DateTime?
  paidById         String?
  paidAt           DateTime?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  archivedAt       DateTime?

  designer   Designer @relation("DesignerBonusPayoutDesigner", fields: [designerId], references: [id])
  createdBy  User     @relation("DesignerBonusPayoutCreatedBy", fields: [createdById], references: [id])
  approvedBy User?    @relation("DesignerBonusPayoutApprovedBy", fields: [approvedById], references: [id])
  paidBy     User?    @relation("DesignerBonusPayoutPaidBy", fields: [paidById], references: [id])

  @@index([designerId])
  @@index([status])
  @@index([payoutDate])
  @@index([createdById])
  @@index([approvedById])
  @@index([paidById])
  @@index([archivedAt])
  @@index([designerId, status, payoutDate])
}

model DesignerBonusAdjustment {
  id             String                      @id @default(cuid())
  designerId     String
  amount         Float
  adjustmentType DesignerBonusAdjustmentType
  reason         String
  comment        String?
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  archivedAt     DateTime?

  designer   Designer @relation("DesignerBonusAdjustmentDesigner", fields: [designerId], references: [id])
  createdBy  User     @relation("DesignerBonusAdjustmentCreatedBy", fields: [createdById], references: [id])
  approvedBy User?    @relation("DesignerBonusAdjustmentApprovedBy", fields: [approvedById], references: [id])

  @@index([designerId])
  @@index([adjustmentType])
  @@index([createdById])
  @@index([approvedById])
  @@index([approvedAt])
  @@index([archivedAt])
  @@index([designerId, approvedAt, createdAt])
}

model SecurityLog {
  id         String              @id @default(cuid())
  action     String
  userId     String?
  entityType AuditEntityType?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  severity   SecurityLogSeverity @default(INFO)
  createdAt  DateTime            @default(now())

  user User? @relation("SecurityLogUser", fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  user User @relation("EmailVerificationTokenUser", fields: [userId], references: [id])

  @@unique([tokenHash])
  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  user User @relation("PasswordResetTokenUser", fields: [userId], references: [id])

  @@unique([tokenHash])
  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  name        String
  role        UserRole
  invitedById String
  tokenHash   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?
  comment     String?

  invitedBy User @relation("UserInvitationInvitedBy", fields: [invitedById], references: [id])

  @@unique([tokenHash])
  @@index([email])
  @@index([role])
  @@index([invitedById])
  @@index([expiresAt])
  @@index([acceptedAt])
  @@index([cancelledAt])
}

model RolePermission {
  id            String   @id @default(cuid())
  role          UserRole
  permissionKey String
  isAllowed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([role, permissionKey])
  @@index([permissionKey])
}
