  revisions           SchedulePlan[]            @relation("SchedulePlanRevision")
  cells               SchedulePlanCell[]
  approvalLogs        SchedulePlanApprovalLog[]
  sourceWorkShifts    WorkShift[]               @relation("WorkShiftSourceSchedulePlan")
  dayStatuses         ScheduleDayStatus[]

  @@unique([locationId, year, month, version])
  @@index([locationId, year, month])
  @@index([status])
  @@index([createdById])
  @@index([submittedById])
  @@index([approvedById])
  @@index([returnedById])
  @@index([basedOnSchedulePlanId])
  @@index([isCurrentApproved])
