model User {
  id                        String    @id @default(cuid())
  name                      String
  email                     String    @unique
  passwordHash              String?
  authProviderId            String?
  role                      UserRole
  isActive                  Boolean   @default(true)
  emailVerifiedAt           DateTime?
  lastLoginAt               DateTime?
  lastPasswordChangeAt      DateTime?
  failedLoginAttempts       Int       @default(0)
  lockedUntil               DateTime?
  deactivatedAt             DateTime?
  deactivatedById           String?
  confidentialityAcceptedAt DateTime?
  profileSettings           Json      @default("{}")
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  clientsResponsible             Client[]                    @relation("ClientResponsible")
  clientsCreated                 Client[]                    @relation("ClientCreatedBy")
  designersResponsible           Designer[]                  @relation("DesignerResponsible")
  designersCreated               Designer[]                  @relation("DesignerCreatedBy")
  objectsResponsible             ProjectObject[]             @relation("ObjectResponsible")
  objectsCreated                 ProjectObject[]             @relation("ObjectCreatedBy")
  objectParticipantsResponsible  ProjectObjectParticipant[]  @relation("ObjectParticipantResponsible")
  objectParticipantsCreated      ProjectObjectParticipant[]  @relation("ObjectParticipantCreatedBy")
  dealsResponsible               Deal[]                      @relation("DealResponsible")
  dealsCreated                   Deal[]                      @relation("DealCreatedBy")
  proposalsResponsible           CommercialProposal[]        @relation("ProposalResponsible")
  proposalsCreated               CommercialProposal[]        @relation("ProposalCreatedBy")
  proposalsUploaded              CommercialProposal[]        @relation("ProposalUploadedBy")
  tasksResponsible               TaskActivity[]              @relation("TaskResponsible")
  tasksCreated                   TaskActivity[]              @relation("TaskCreatedBy")
  auditLogs                      AuditLog[]                  @relation("AuditLogUser")
  crmViolationsResponsible       CrmViolation[]              @relation("CrmViolationResponsible")
  crmViolationsResolved          CrmViolation[]              @relation("CrmViolationResolvedBy")
  bonusAgreementsCreated         DesignerBonusAgreement[]    @relation("DesignerBonusAgreementCreatedBy")
  bonusAgreementsApproved        DesignerBonusAgreement[]    @relation("DesignerBonusAgreementApprovedBy")
  paymentsCreated                Payment[]                   @relation("PaymentCreatedBy")
  paymentsConfirmed              Payment[]                   @relation("PaymentConfirmedBy")
  bonusAccrualsCreated           DesignerBonusAccrual[]      @relation("DesignerBonusAccrualCreatedBy")
  bonusAccrualsApproved          DesignerBonusAccrual[]      @relation("DesignerBonusAccrualApprovedBy")
  bonusPayoutsCreated            DesignerBonusPayout[]       @relation("DesignerBonusPayoutCreatedBy")
  bonusPayoutsApproved           DesignerBonusPayout[]       @relation("DesignerBonusPayoutApprovedBy")
  bonusPayoutsPaid               DesignerBonusPayout[]       @relation("DesignerBonusPayoutPaidBy")
  bonusAdjustmentsCreated        DesignerBonusAdjustment[]   @relation("DesignerBonusAdjustmentCreatedBy")
  bonusAdjustmentsApproved       DesignerBonusAdjustment[]   @relation("DesignerBonusAdjustmentApprovedBy")
  securityLogs                   SecurityLog[]               @relation("SecurityLogUser")
  employeeProfile                EmployeeProfile?            @relation("EmployeeProfileUser")
  workShiftsCreated              WorkShift[]                 @relation("WorkShiftCreatedBy")
  locationDisplayDevicesApproved LocationDisplayDevice[]     @relation("LocationDisplayDeviceApprovedBy")
  locationDisplayDevicesRevoked  LocationDisplayDevice[]     @relation("LocationDisplayDeviceRevokedBy")
  displaySetupTokensCreated      LocationDisplaySetupToken[] @relation("LocationDisplaySetupTokenCreatedBy")
  timeEvents                     TimeEvent[]                 @relation("TimeEventUser")
  timeEventsReviewed             TimeEvent[]                 @relation("TimeEventReviewedBy")
  timesheetDays                  TimesheetDay[]              @relation("TimesheetDayUser")
  timeAdjustmentRequests         TimeAdjustmentRequest[]     @relation("TimeAdjustmentRequestUser")
  timeAdjustmentRequestsReviewed TimeAdjustmentRequest[]     @relation("TimeAdjustmentRequestReviewedBy")
  schedulePlansCreated           SchedulePlan[]              @relation("SchedulePlanCreatedBy")
  schedulePlansSubmitted         SchedulePlan[]              @relation("SchedulePlanSubmittedBy")
  schedulePlansApproved          SchedulePlan[]              @relation("SchedulePlanApprovedBy")
  schedulePlansReturned          SchedulePlan[]              @relation("SchedulePlanReturnedBy")
  schedulePlanCells              SchedulePlanCell[]          @relation("SchedulePlanCellUser")
  schedulePlanApprovalLogs       SchedulePlanApprovalLog[]   @relation("SchedulePlanApprovalLogActor")
  scheduleDayStatuses            ScheduleDayStatus[]         @relation("ScheduleDayStatusUser")
  employeeDevicesApproved        EmployeeTrustedDevice[]     @relation("EmployeeTrustedDeviceApprovedBy")
  employeeDevicesBlocked         EmployeeTrustedDevice[]     @relation("EmployeeTrustedDeviceBlockedBy")
  deactivatedBy                  User?                       @relation("UserDeactivatedBy", fields: [deactivatedById], references: [id])
  deactivatedUsers               User[]                      @relation("UserDeactivatedBy")
  emailVerificationTokens        EmailVerificationToken[]    @relation("EmailVerificationTokenUser")
  passwordResetTokens            PasswordResetToken[]        @relation("PasswordResetTokenUser")
  invitationsSent                UserInvitation[]            @relation("UserInvitationInvitedBy")

  @@index([role])
  @@index([isActive])
  @@index([emailVerifiedAt])
  @@index([lockedUntil])
  @@index([deactivatedById])
}

model Client {
  id               String       @id @default(cuid())
  name             String
  clientType       ClientType   @default(INDIVIDUAL)
  phone            String?
  email            String?
  messenger        String?
  city             String?
  source           ClientSource @default(SHOWROOM)
  linkedDesignerId String?
  responsibleId    String
  status           ClientStatus @default(NEW)
  comment          String?
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  archivedAt       DateTime?
  lastContactAt    DateTime?
  nextContactAt    DateTime?
  notes            String?

  responsible    User                   @relation("ClientResponsible", fields: [responsibleId], references: [id])
  createdBy      User                   @relation("ClientCreatedBy", fields: [createdById], references: [id])
  linkedDesigner Designer?              @relation("ClientLinkedDesigner", fields: [linkedDesignerId], references: [id])
  projectObjects ProjectObject[]        @relation("ObjectClient")
  deals          Deal[]                 @relation("DealClient")
  proposals      CommercialProposal[]   @relation("ProposalClient")
  tasks          TaskActivity[]         @relation("TaskClient")
  payments       Payment[]              @relation("PaymentClient")
  bonusAccruals  DesignerBonusAccrual[] @relation("DesignerBonusAccrualClient")

  @@index([responsibleId])
  @@index([createdById])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([nextContactAt])
  @@index([responsibleId, status, nextContactAt])
  @@index([responsibleId, createdAt])
}

model Designer {
  id                      String                    @id @default(cuid())
  name                    String
  studio                  String?
  role                    DesignerRole              @default(DESIGNER)
  phone                   String?
  email                   String?
  messenger               String?
  website                 String?
  city                    String?
  specialization          DesignerSpecialization[]
  projectSegment          DesignerProjectSegment?
  source                  DesignerSource            @default(DATABASE)
  responsibleId           String
  relationshipStage       DesignerRelationshipStage @default(NEW_CONTACT)
  potential               DesignerPotential         @default(B)
  loyalty                 DesignerLoyalty           @default(NEUTRAL)
  cooperationTerms        String?
  firstContactAt          DateTime?
  lastTouchAt             DateTime?
  nextStepAt              DateTime?
  nextStepText            String?
  transferredObjectsCount Int                       @default(0)
  activeObjectsCount      Int                       @default(0)
  proposalsTotalAmount    Float                     @default(0)
  paymentsTotalAmount     Float                     @default(0)
  comment                 String?
  status                  EntityStatus              @default(ACTIVE)
  createdById             String
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  archivedAt              DateTime?
  notes                   String?

  responsible      User                      @relation("DesignerResponsible", fields: [responsibleId], references: [id])
  createdBy        User                      @relation("DesignerCreatedBy", fields: [createdById], references: [id])
  linkedClients    Client[]                  @relation("ClientLinkedDesigner")
  projectObjects   ProjectObject[]           @relation("ObjectDesigner")
  deals            Deal[]                    @relation("DealDesigner")
  proposals        CommercialProposal[]      @relation("ProposalDesigner")
  tasks            TaskActivity[]            @relation("TaskDesigner")
  bonusAgreements  DesignerBonusAgreement[]  @relation("DesignerBonusAgreementDesigner")
  payments         Payment[]                 @relation("PaymentDesigner")
  bonusAccruals    DesignerBonusAccrual[]    @relation("DesignerBonusAccrualDesigner")
  bonusPayouts     DesignerBonusPayout[]     @relation("DesignerBonusPayoutDesigner")
  bonusAdjustments DesignerBonusAdjustment[] @relation("DesignerBonusAdjustmentDesigner")

  @@index([responsibleId])
  @@index([createdById])
  @@index([relationshipStage])
  @@index([potential])
  @@index([loyalty])
  @@index([status])
  @@index([source])
  @@index([createdAt])
  @@index([lastTouchAt])
  @@index([nextStepAt])
  @@index([responsibleId, relationshipStage, lastTouchAt])
  @@index([responsibleId, nextStepAt])
}

model ProjectObject {
  id                    String                   @id @default(cuid())
  title                 String
  objectType            ObjectType
  city                  String
  region                String?
  address               String?
  clientId              String
  designerId            String?
  responsibleId         String
  stage                 ObjectStage              @default(NEW_OBJECT)
  status                ObjectStatus             @default(ACTIVE)
  implementationStartAt DateTime?
  implementationEndAt   DateTime?
  budget                Float?
  bathroomsCount        Int?
  interestCategories    ObjectInterestCategory[]
  files                 String[]                 @default([])
  comment               String?
  createdById           String
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  archivedAt            DateTime?
  notes                 String?

  client        Client                     @relation("ObjectClient", fields: [clientId], references: [id])
  designer      Designer?                  @relation("ObjectDesigner", fields: [designerId], references: [id])
  responsible   User                       @relation("ObjectResponsible", fields: [responsibleId], references: [id])
  createdBy     User                       @relation("ObjectCreatedBy", fields: [createdById], references: [id])
  participants  ProjectObjectParticipant[] @relation("ObjectParticipants")
  deals         Deal[]                     @relation("DealObject")
  proposals     CommercialProposal[]       @relation("ProposalObject")
  tasks         TaskActivity[]             @relation("TaskObject")
  payments      Payment[]                  @relation("PaymentObject")
  bonusAccruals DesignerBonusAccrual[]     @relation("DesignerBonusAccrualObject")

  @@index([responsibleId])
  @@index([createdById])
  @@index([clientId])
  @@index([designerId])
  @@index([stage])
  @@index([status])
  @@index([objectType])
  @@index([createdAt])
  @@index([responsibleId, status, stage])
  @@index([responsibleId, createdAt])
}

model ProjectObjectParticipant {
  id                 String                       @id @default(cuid())
  objectId           String
  participantType    ProjectObjectParticipantType
  fullName           String
  company            String?
  role               String
  phone              String?
  email              String?
  messenger          String?
  responsibleId      String?
  comment            String?
  influenceLevel     InfluenceLevel?
  influenceType      InfluenceType?
  attitudeToSturm    AttitudeToSturm?
  decisionFactors    String?
  responsibilityZone String?
  canApproveChanges  ChangeApproval?
  whenToInvolve      String?
  createdById        String
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt
  archivedAt         DateTime?

  object      ProjectObject  @relation("ObjectParticipants", fields: [objectId], references: [id])
  responsible User?          @relation("ObjectParticipantResponsible", fields: [responsibleId], references: [id])
  createdBy   User           @relation("ObjectParticipantCreatedBy", fields: [createdById], references: [id])
  tasks       TaskActivity[] @relation("TaskObjectParticipant")
}

model Deal {
  id              String           @id @default(cuid())
  title           String
  clientId        String
  objectId        String
  designerId      String?
  responsibleId   String
  stage           DealStage        @default(NEW_REQUEST)
  potentialAmount Float?
  probability     DealProbability?
  nextActionAt    DateTime?
  nextActionText  String?
  source          DealSource
  lossReason      DealLossReason?
  lossComment     String?
  comment         String?
  createdById     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  archivedAt      DateTime?
  closedAt        DateTime?
  notes           String?

  client        Client                 @relation("DealClient", fields: [clientId], references: [id])
  projectObject ProjectObject          @relation("DealObject", fields: [objectId], references: [id])
  designer      Designer?              @relation("DealDesigner", fields: [designerId], references: [id])
  responsible   User                   @relation("DealResponsible", fields: [responsibleId], references: [id])
  createdBy     User                   @relation("DealCreatedBy", fields: [createdById], references: [id])
  proposals     CommercialProposal[]   @relation("ProposalDeal")
  tasks         TaskActivity[]         @relation("TaskDeal")
  payments      Payment[]              @relation("PaymentDeal")
  bonusAccruals DesignerBonusAccrual[] @relation("DesignerBonusAccrualDeal")

  @@index([responsibleId])
  @@index([createdById])
  @@index([clientId])
  @@index([objectId])
  @@index([designerId])
  @@index([stage])
  @@index([source])
  @@index([probability])
  @@index([nextActionAt])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([responsibleId, stage, archivedAt, nextActionAt])
  @@index([responsibleId, createdAt])
}

model CommercialProposal {
  id                   String                   @id @default(cuid())
  proposalNumber       String                   @unique
  dealId               String
  clientId             String
  objectId             String
  designerId           String?
  responsibleId        String
  version              Int                      @default(1)
  parentProposalId     String?
  amount               Float
  discountPercent      Float?
  discountAmount       Float?
  status               CommercialProposalStatus @default(DRAFT)
  recipientType        RecipientType?
  recipientName        String?
  recipientContact     String?
  approvalRequiredFrom String?
  sentAt               DateTime?
  nextTouchAt          DateTime?
  fileUrl              String?
  fileName             String?
  fileSize             Int?
  fileMimeType         String?
  uploadedById         String?
  uploadedAt           DateTime?
  declineReason        ProposalDeclineReason?
  declineComment       String?
  comment              String?
  createdById          String
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  archivedAt           DateTime?
  notes                String?

  deal          Deal                 @relation("ProposalDeal", fields: [dealId], references: [id])
  client        Client               @relation("ProposalClient", fields: [clientId], references: [id])
  projectObject ProjectObject        @relation("ProposalObject", fields: [objectId], references: [id])
