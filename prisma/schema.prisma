  @@index([employeeId, occurredAt])
  @@index([locationId, occurredAt])
}

model TimesheetDay {
  id                String             @id @default(cuid())
  employeeId        String
  userId            String
  date              String
  shiftId           String?
  scheduleDayStatusId String?             @unique
  locationId        String?
  plannedStart      DateTime?
  plannedEnd        DateTime?
  actualCheckIn     DateTime?
  actualCheckOut    DateTime?
  workedMinutes     Int                @default(0)
  lateMinutes       Int                @default(0)
  earlyLeaveMinutes Int                @default(0)
  overtimeMinutes   Int                @default(0)
  status            TimesheetDayStatus @default(SCHEDULED)
  hasPendingEvents  Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  employee EmployeeProfile @relation(fields: [employeeId], references: [id])
  user     User            @relation("TimesheetDayUser", fields: [userId], references: [id])
  shift    WorkShift?      @relation(fields: [shiftId], references: [id])
  scheduleDayStatus ScheduleDayStatus? @relation(fields: [scheduleDayStatusId], references: [id])
  location WorkLocation?   @relation(fields: [locationId], references: [id])

  @@unique([employeeId, date])
  @@index([userId])
  @@index([date])
  @@index([shiftId])
  @@index([scheduleDayStatusId])
  @@index([locationId])
  @@index([locationId, date])
  @@index([status])
  @@index([hasPendingEvents])
}

model TimeAdjustmentRequest {
  id                  String               @id @default(cuid())
  employeeId          String
  userId              String
  shiftId             String?
  date                String
  requestedAction     TimeAdjustmentAction
  eventType           TimeEventType?
  targetEventId       String?
  requestedOccurredAt DateTime?
  comment             String
  status              TimeAdjustmentStatus @default(PENDING)
  reviewedById        String?
  reviewedAt          DateTime?
  reviewComment       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])
  user        User            @relation("TimeAdjustmentRequestUser", fields: [userId], references: [id])
  shift       WorkShift?      @relation(fields: [shiftId], references: [id])
  targetEvent TimeEvent?      @relation("TimeAdjustmentTargetEvent", fields: [targetEventId], references: [id])
  reviewedBy  User?           @relation("TimeAdjustmentRequestReviewedBy", fields: [reviewedById], references: [id])

  @@index([employeeId])
  @@index([employeeId, date])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([reviewedById])
}

model SecurityLog {
  id         String              @id @default(cuid())
  action     String
  userId     String?
  entityType AuditEntityType?
  entityId   String?
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  severity   SecurityLogSeverity @default(INFO)
  createdAt  DateTime            @default(now())

  user User? @relation("SecurityLogUser", fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([severity])
  @@index([createdAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  user User @relation("EmailVerificationTokenUser", fields: [userId], references: [id])

  @@unique([tokenHash])
  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  ipAddress String?
  userAgent String?

  user User @relation("PasswordResetTokenUser", fields: [userId], references: [id])

  @@unique([tokenHash])
  @@index([userId])
  @@index([email])
  @@index([expiresAt])
  @@index([usedAt])
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  name        String
  role        UserRole
  invitedById String
  tokenHash   String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  cancelledAt DateTime?
  comment     String?

  invitedBy User @relation("UserInvitationInvitedBy", fields: [invitedById], references: [id])

  @@unique([tokenHash])
  @@index([email])
  @@index([role])
  @@index([invitedById])
  @@index([expiresAt])
  @@index([acceptedAt])
  @@index([cancelledAt])
}

model RolePermission {
  id            String   @id @default(cuid())
  role          UserRole
  permissionKey String
  isAllowed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([role, permissionKey])
  @@index([permissionKey])
}
