POSTGRES_DB=sturm_crm
POSTGRES_USER=sturm
POSTGRES_PASSWORD=replace-with-strong-postgres-password

APP_PORT=3000
NEXTAUTH_URL=https://crm.example.com
APP_URL=https://crm.example.com
NEXTAUTH_SECRET=replace-with-long-random-secret

RESEND_API_KEY=
EMAIL_FROM=STURM CRM <no-reply@example.com>
SUPPORT_EMAIL=support@example.com

# DANGER: true deletes existing database data and reapplies migrations.
RESET_DATABASE=false

# Run once on first production deploy to create the initial OWNER admin only.
RUN_SEED=false
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=replace-with-strong-initial-admin-password
INITIAL_ADMIN_NAME=Администратор
SKIP_MIGRATIONS=false
